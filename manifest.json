{
  "manifest_version": 3,
  "name": "Convert Currency TBH USD to IDR",
  "version": "1.0.0",
  "description": "Mengubah tampilan harga USD menjadi Rupiah di Wiki Taskbar Hero.",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["https://api.frankfurter.dev/*"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "TBH USD ke IDR",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://taskbarhero.wiki/*",
        "https://www.taskbarhero.wiki/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
